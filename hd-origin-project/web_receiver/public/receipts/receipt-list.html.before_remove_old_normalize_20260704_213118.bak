    }

    #formArea #taxBreakdownButton {
      width: 100% !important;
      min-width: 0 !important;
      max-width: 100% !important;
      padding-left: 0.2rem !important;
      padding-right: 0.2rem !important;
      font-size: 0.68rem !important;
      white-space: nowrap !important;
      overflow: hidden !important;
      box-sizing: border-box !important;
    }

    /* RECEIPT_AMOUNT_TAX_ROW_HTML_FIX_20260704_END */


    /* RECEIPT_DATE_TIME_INLINE_HTML_20260704_START */
    /*
      HTML側で取引日・時刻を .receipt-date-time-inline-row にまとめる。
      横並び表示用。
    */

    #formArea .receipt-date-time-inline-row {
      display: grid !important;
      grid-template-columns: 10rem 6rem !important;
      gap: 0.5rem !important;
      align-items: end !important;
      width: max-content !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
    }

    #formArea .receipt-date-time-inline-row > div {
      min-width: 0 !important;
      box-sizing: border-box !important;
    }

    #formArea #transactionDate {
      width: 10rem !important;
      max-width: 10rem !important;
      box-sizing: border-box !important;
    }

    #formArea #receiptTimeText {
      width: 6rem !important;
      max-width: 6rem !important;
      text-align: center !important;
      box-sizing: border-box !important;
    }

    /* RECEIPT_DATE_TIME_INLINE_HTML_20260704_END */



    /* RECEIPT_VENDOR_NAME_2LINES_20260704_START */
    /*
      店名・支払先の枠を2行分確保する。
      id は vendorName のまま。
    */

    #formArea #vendorName {
      min-height: 3.2rem !important;
