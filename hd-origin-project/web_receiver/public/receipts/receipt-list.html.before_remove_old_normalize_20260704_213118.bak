      resize: vertical !important;
      line-height: 1.35 !important;
      box-sizing: border-box !important;
    }

    /* RECEIPT_VENDOR_NAME_2LINES_20260704_END */


    /* RECEIPT_INVOICE_NOTE_RIGHT_WIDTH_20260704_START */
    /*
      インボイス番号ラベルの右横にレスポンスメッセージを置く。
      幅調整のみ。HTML構造は触らない。
    */

    #formArea .receipt-invoice-label-row {
      display: grid !important;
      grid-template-columns: 8rem minmax(0, 1fr) !important;
      gap: 0.5rem !important;
      align-items: center !important;
      width: 100% !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
    }

    #formArea .receipt-invoice-label-row label {
      margin: 0 !important;
      white-space: nowrap !important;
    }

    #formArea .receipt-invoice-label-row .invoice-note-wrap {
      margin: 0 !important;
      padding: 0 !important;
      min-width: 0 !important;
      max-width: 100% !important;
