    /* RECEIPT_AMOUNT_TAX_ROW_HTML_FIX_20260704_START */
    /*
      支払方法は上段。
      合計金額・消費税合計・消費税内訳ボタンは .receipt-amount-tax-row 内で横並び。
      ブルーエリア内に収める。
    */

    #formArea .receipt-amount-direct-row {
      display: grid !important;
      grid-template-columns: minmax(0, 1fr) !important;
      row-gap: 0.45rem !important;
