<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <title>レシート読取確認</title>
  <style>
    body {
      margin: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #f4f4f4;
      color: #222;
    }

    header {
      height: 3rem;
      box-sizing: border-box;
      padding: 0.75rem 1rem;
      background: #222;
      color: #fff;
      font-size: 1.125rem;
      font-weight: 700;
    }

    main {
      display: grid;
      grid-template-columns: 18.75rem 1fr 32.5rem;
      gap: 0.625rem;
      padding: 0.625rem;
      height: calc(100vh - 3rem);
      box-sizing: border-box;
    }

    .panel {
      background: #fff;
      border: 0.0625rem solid #ddd;
      border-radius: 0.5rem;
      overflow: hidden;
      min-height: 0;
    }

    .panel-title {
      height: 2.625rem;
      box-sizing: border-box;
      padding: 0.5625rem 0.625rem;
      border-bottom: 0.0625rem solid #ddd;
      background: #fafafa;
      font-weight: 700;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
    }

    .scroll {
      height: calc(100% - 2.625rem);
      overflow: auto;
    }

    .list-item {
      padding: 0.625rem;
      border-bottom: 0.0625rem solid #eee;
      cursor: pointer;
    }

    .list-item:hover {
      background: #f0f4ff;
    }

    .list-item.active {
      background: #e8f0ff;
      border-left: 0.25rem solid #333;
    }

    .list-main {
      font-weight: 700;
      margin-bottom: 0.25rem;
    }

    .list-sub {
      font-size: 0.75rem;
      color: #666;
      line-height: 1.5;
      word-break: break-all;
    }

    .image-area {
      height: calc(100% - 2.625rem);
      overflow: auto;
      background: #eee;
      text-align: center;
      padding: 0.625rem;
      box-sizing: border-box;
    }

    .image-area img {
      max-width: 100%;
      border: 0.0625rem solid #ccc;
      background: #fff;
    }

    .form-area {
      height: calc(100% - 2.625rem);
      overflow: auto;
      padding: 0.625rem;
      box-sizing: border-box;
    }

    .block {
      border: 0.0625rem solid #ddd;
      border-radius: 0.5rem;
      margin-bottom: 0.625rem;
      overflow: hidden;
      background: #fff;
    }

    .block-title {
      padding: 0.5rem 0.625rem;
      background: #fafafa;
      border-bottom: 0.0625rem solid #ddd;
      font-weight: 700;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
    }

    .block-body {
      padding: 0.625rem;
    }

    label {
      display: block;
      font-size: 0.75rem;
      font-weight: 700;
      margin-bottom: 0.25rem;
      color: #444;
    }

    input, textarea, select {
      width: 100%;
      box-sizing: border-box;
      padding: 0.4375rem;
      border: 0.0625rem solid #bbb;
      border-radius: 0.3125rem;
      font-size: 0.875rem;
      background: #fff;
    }

    textarea {
      min-height: 4rem;
      resize: vertical;
    }

    .grid2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }

    .grid1 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }

    button {
      border: 0.0625rem solid #aaa;
      background: #fff;
      padding: 0.4375rem 0.625rem;
      border-radius: 0.375rem;
      cursor: pointer;
    }

    button:hover {
      background: #f2f2f2;
    }

    button.primary {
      background: #222;
      color: #fff;
      border-color: #222;
    }

    button.primary:hover {
      background: #444;
    }

    button.danger {
      color: #b00020;
      border-color: #d8a0aa;
    }

    .actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 0.625rem;
    }

    .muted {
      color: #777;
      font-size: 0.75rem;
    }

    .warn {
      color: #b00020;
      font-weight: 700;
    }

    .ok {
      color: #087a28;
      font-weight: 700;
    }

    table.lines {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.8125rem;
    }

    table.lines th,
    table.lines td {
      border: 0.0625rem solid #ddd;
      padding: 0.3125rem;
      vertical-align: top;
    }

    table.lines th {
      background: #fafafa;
      font-weight: 700;
      white-space: nowrap;
    }

    table.lines input {
      padding: 0.3125rem;
      font-size: 0.8125rem;
    }

    .line-name {
      min-width: 9.375rem;
    }

    .line-small {
      width: 4.375rem;
    }

    .line-money {
      width: 5.625rem;
    }

    pre {
      white-space: pre-wrap;
      word-break: break-all;
      background: #111;
      color: #eee;
      padding: 0.625rem;
      border-radius: 0.375rem;
      font-size: 0.75rem;
      line-height: 1.5;
      max-height: 11.25rem;
      overflow: auto;
    }
  
    /* RECEIPT_HEADER_IMPORT_NAV */
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    header h1 {
      margin: 0;
    }

    .receipt-header-actions {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-left: auto;
    }

    .receipt-header-actions button {
      background: #fff;
      color: #111;
      border: 0.0625rem solid #fff;
      border-radius: 0.5rem;
      padding: 0.45rem 0.75rem;
      font-weight: 800;
      cursor: pointer;
      white-space: nowrap;
    }

    .receipt-header-actions button:hover {
      background: #f1f1f1;
    }
  
    /* RECEIPT_COMPACT_ACCOUNTING_LAYOUT */
    body {
      overflow: hidden;
    }

    .receipt-compact-layout {
      display: grid !important;
      grid-template-columns: 11.875rem minmax(42.5rem, 1fr) 20.625rem !important;
      gap: 0.375rem !important;
      height: calc(100vh - 3.625rem) !important;
      padding: 0.375rem 0.5rem !important;
      box-sizing: border-box !important;
      overflow: hidden !important;
    }

    .receipt-compact-layout > * {
      min-width: 0 !important;
      min-height: 0 !important;
      overflow: hidden !important;
    }

    .receipt-list-panel {
      order: 1 !important;
    }

    .receipt-candidate-panel {
      order: 2 !important;
    }

    .receipt-image-panel {
      order: 3 !important;
    }

    .receipt-list-panel .panel-title,
    .receipt-candidate-panel .panel-title,
    .receipt-image-panel .panel-title {
      padding: 0.375rem 0.5rem !important;
      font-size: 0.875rem !important;
      line-height: 1.2 !important;
    }

    .receipt-list-panel button,
    .receipt-list-panel .item {
      font-size: 0.75rem !important;
      line-height: 1.25 !important;
      padding: 0.375rem 0.4375rem !important;
    }

    .receipt-list-panel small,
    .receipt-list-panel .meta,
    .receipt-list-panel .sub {
      font-size: 0.625rem !important;
      line-height: 1.2 !important;
    }

    .receipt-list-panel {
      font-size: 0.75rem !important;
    }

    .receipt-candidate-panel {
      font-size: 0.75rem !important;
    }

    .receipt-image-panel {
      font-size: 0.75rem !important;
    }

    #formArea {
      height: calc(100vh - 7rem) !important;
      overflow: auto !important;
      padding: 0.5rem !important;
      box-sizing: border-box !important;
    }

    #formArea input,
    #formArea select,
    #formArea textarea {
      font-size: 0.75rem !important;
      padding: 0.25rem 0.375rem !important;
      min-height: 1.625rem !important;
      box-sizing: border-box !important;
    }

    #formArea textarea {
      min-height: 3rem !important;
      max-height: 4.75rem !important;
    }

    #formArea table {
      width: 100% !important;
      table-layout: fixed !important;
      font-size: 0.75rem !important;
    }

    #formArea th,
    #formArea td {
      padding: 0.1875rem !important;
      font-size: 0.75rem !important;
      vertical-align: middle !important;
    }

    #formArea button {
      font-size: 0.75rem !important;
      padding: 0.3125rem 0.5rem !important;
      min-height: 1.75rem !important;
    }

    #formArea .card,
    #formArea .section,
    #formArea fieldset {
      margin-bottom: 0.5rem !important;
      padding: 0.5rem !important;
    }

    #imageArea {
      height: calc(100vh - 7rem) !important;
      overflow: hidden !important;
      padding: 0.375rem !important;
      box-sizing: border-box !important;
      display: flex !important;
      align-items: flex-start !important;
      justify-content: center !important;
      background: #fff !important;
    }

    #imageArea img {
      max-width: 100% !important;
      max-height: 100% !important;
      width: auto !important;
      height: auto !important;
      object-fit: contain !important;
      cursor: zoom-in !important;
    }

    #receiptImageModal {
      position: fixed;
      inset: 0;
      z-index: 99999;
      display: none;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.78);
      padding: 1.125rem;
      box-sizing: border-box;
    }

    #receiptImageModal img {
      max-width: 96vw;
      max-height: 94vh;
      object-fit: contain;
      background: #fff;
      border-radius: 0.5rem;
      cursor: zoom-out;
    }

    #receiptImageModal .modal-note {
      position: fixed;
      top: 0.625rem;
      right: 1rem;
      color: #fff;
      font-size: 0.8125rem;
      background: rgba(0,0,0,0.45);
      padding: 0.375rem 0.625rem;
      border-radius: 0.375rem;
    }

    @media (max-width: 81.25rem) {
      .receipt-compact-layout {
        grid-template-columns: 10.625rem minmax(35rem, 1fr) 17.5rem !important;
      }
    }
/* RECEIPT_LEFT_LIST_ONE_LINE_AND_COMPACT_BASIC removed by editor card layout repair */
/* RECEIPT_FIELD_LAYOUT removed by editor card layout repair */
/* RECEIPT_CONFIRM_IMAGE_FIT removed by editor card layout repair */

/* RECEIPT_BASIC_DIRECT_LAYOUT removed by editor card layout repair */
/* RECEIPT_PAYMENT_MAX_WIDTH removed by editor card layout repair */
/* RECEIPT_TAX_TREATMENT_LAYOUT removed by editor card layout repair */


    /* RECEIPT_TAX_BREAKDOWN_MODAL_STYLE_START */

    .tax-total-with-button {
      display: grid !important;
      grid-template-columns: minmax(8em, 1fr) auto !important;
      gap: 0.5rem !important;
      align-items: center !important;
      width: 100% !important;
    }

    #taxAmount {
      width: 100% !important;
      min-width: 8em !important;
    }

    #taxBreakdownButton {
      white-space: nowrap !important;
      height: 2.4rem !important;
      padding: 0 0.8rem !important;
    }

    #formArea .grid-tax-row > div:has(#taxRate),
    #formArea .grid-tax-row > div:has(#taxTreatmentName) {
      display: none !important;
    }

    #formArea .grid-tax-row {
      grid-template-columns: minmax(16em, 1fr) !important;
    }

    .tax-breakdown-modal.hidden {
      display: none !important;
    }

    .tax-breakdown-modal {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: grid;
      place-items: center;
    }

    .tax-breakdown-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.35);
    }

    .tax-breakdown-dialog {
      position: relative;
      width: min(64rem, calc(100vw - 3rem));
      max-height: calc(100dvh - 3rem);
      background: #fff;
      border-radius: 0.75rem;
      box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.25);
      display: grid;
      grid-template-rows: auto 1fr auto;
      overflow: hidden;
    }

    .tax-breakdown-header {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: start;
      padding: 1rem 1.25rem;
      border-bottom: 0.0625rem solid #ddd;
    }

    .tax-breakdown-title {
      font-size: 1.2rem;
      font-weight: 700;
    }

    .tax-breakdown-subtitle {
      margin-top: 0.25rem;
      color: #666;
      font-size: 0.9rem;
    }

    .tax-breakdown-close {
      font-size: 1.4rem;
      line-height: 1;
      width: 2.4rem;
      height: 2.4rem;
    }

    .tax-breakdown-body {
      overflow: auto;
      padding: 1rem 1.25rem;
    }

    .tax-breakdown-table {
      width: 100%;
      border-collapse: collapse;
    }

    .tax-breakdown-table th,
    .tax-breakdown-table td {
      border-bottom: 0.0625rem solid #e5e5e5;
      padding: 0.45rem;
      vertical-align: middle;
      text-align: left;
    }

    .tax-breakdown-table th {
      font-size: 0.85rem;
      color: #555;
      white-space: nowrap;
    }

    .tax-breakdown-table select,
    .tax-breakdown-table input {
      width: 100%;
      box-sizing: border-box;
    }

    .tax-breakdown-footer {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: center;
      padding: 1rem 1.25rem;
      border-top: 0.0625rem solid #ddd;
    }

    .tax-breakdown-total {
      font-weight: 700;
    }

    .tax-breakdown-actions {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    .tax-breakdown-delete-button {
      background: #b00020 !important;
      color: #fff !important;
      border-color: #b00020 !important;
      white-space: nowrap !important;
    }

    .tax-breakdown-delete-button:hover {
      background: #8a0019 !important;
      border-color: #8a0019 !important;
    }

    /* RECEIPT_TAX_BREAKDOWN_MODAL_STYLE_END */
/* RECEIPT_BASIC_TOP_FINAL_LAYOUT_20260702 removed by editor card layout repair */
/* RECEIPT_LAYOUT_ONLY_FINAL_20260702 removed by editor card layout repair */
/* RECEIPT_OVERLAP_FIX_20260702 removed by editor card layout repair */
/* RECEIPT_TAX_BUTTON_OVERLAP_FIX_20260702 removed by editor card layout repair */


    /* RECEIPT_LIST_CHECKBOX_20260702_START */

    .receipt-list-with-check {
      display: grid !important;
      grid-template-columns: auto minmax(0, 1fr) !important;
      column-gap: 0.45rem !important;
      row-gap: 0.1rem !important;
      align-items: start !important;
    }

    .receipt-list-with-check .receipt-ai-check {
      grid-column: 1 !important;
      grid-row: 1 / span 2 !important;
      width: 1rem !important;
      min-width: 1rem !important;
      height: 1rem !important;
      min-height: 1rem !important;
      margin: 0.15rem 0 0 0 !important;
      padding: 0 !important;
      cursor: pointer !important;
    }

    .receipt-list-with-check .list-main {
      grid-column: 2 !important;
      grid-row: 1 !important;
      min-width: 0 !important;
    }

    .receipt-list-with-check .list-sub {
      grid-column: 2 !important;
      grid-row: 2 !important;
      min-width: 0 !important;
    }

    /* RECEIPT_LIST_CHECKBOX_20260702_END */


    /* RECEIPT_MASTER_FIELDS_LAYOUT_20260703_START */

    #formArea .receipt-master-select-row {
      display: grid !important;
      grid-template-columns: repeat(3, minmax(10em, 1fr)) !important;
      gap: 0.5rem !important;
      width: 100% !important;
      margin-top: 0.45rem !important;
    }

    #formArea .receipt-master-select-row > div {
      min-width: 0 !important;
    }

    #formArea .receipt-master-select-row select,
    #formArea .receipt-master-select-row input {
      width: 100% !important;
      height: 1.65rem !important;
      min-height: 1.65rem !important;
      box-sizing: border-box !important;
    }

    /* RECEIPT_MASTER_FIELDS_LAYOUT_20260703_END */


    /* RECEIPT_TEMP_MASTER_INPUT_LAYOUT_20260703_START */

    #formArea .receipt-master-combo-row {
      display: grid !important;
      grid-template-columns: repeat(3, minmax(13em, 1fr)) !important;
      gap: 0.5rem !important;
      width: 100% !important;
      margin-top: 0.45rem !important;
    }

    #formArea .receipt-master-action-line {
      display: grid !important;
      grid-template-columns: minmax(8em, 1fr) auto auto !important;
      gap: 0.25rem !important;
      align-items: center !important;
    }

    #formArea .receipt-master-action-line select {
      width: 100% !important;
      min-width: 0 !important;
      height: 1.65rem !important;
    }

    #formArea .receipt-master-action-line button {
      white-space: nowrap !important;
      padding: 0.25rem 0.4rem !important;
      font-size: 0.72rem !important;
      line-height: 1.1 !important;
      min-height: 1.65rem !important;
    }

    #formArea .receipt-temp-master-input {
      width: 100% !important;
      margin-top: 0.25rem !important;
      height: 1.65rem !important;
      box-sizing: border-box !important;
    }

    /* RECEIPT_TEMP_MASTER_INPUT_LAYOUT_20260703_END */


    /* RECEIPT_VENDOR_OVERFLOW_FIX_20260703 removed by group layout cleanup */

    /* RECEIPT_BASIC_BLOCK_MOVE_20260703 removed by group layout cleanup */

    /* RECEIPT_INVOICE_EVIDENCE_RIGHT_FIX_20260703 removed by group layout cleanup */

    /* RECEIPT_INVOICE_EVIDENCE_RIGHT_FORCE_FIX_2_20260703 removed by group layout cleanup */

    /* RECEIPT_COPY_SYSTEM_STYLE_20260703_START */

    .receipt-copy-system-panel {
      border: 0.0625rem solid #d8c7c7 !important;
      background: #fffafa !important;
      border-radius: 0.45rem !important;
      padding: 0.6rem !important;
      margin-bottom: 0.75rem !important;
      box-sizing: border-box !important;
    }

    .receipt-copy-system-title {
      font-weight: 700 !important;
      margin-bottom: 0.4rem !important;
      color: #7a0015 !important;
      display: flex !important;
      justify-content: space-between !important;
      align-items: center !important;
      gap: 0.5rem !important;
    }

    .receipt-copy-system-buttons {
      display: flex !important;
      flex-wrap: wrap !important;
      gap: 0.35rem !important;
      margin-bottom: 0.4rem !important;
    }

    .receipt-copy-system-buttons button {
      padding: 0.3rem 0.55rem !important;
      font-size: 0.78rem !important;
      line-height: 1.2 !important;
      cursor: pointer !important;
    }

    #receiptCopySystemText {
      width: 100% !important;
      min-height: 8rem !important;
      max-height: 18rem !important;
      resize: vertical !important;
      box-sizing: border-box !important;
      font-family: Consolas, "Yu Gothic", monospace !important;
      font-size: 0.8rem !important;
      line-height: 1.45 !important;
      white-space: pre !important;
      user-select: text !important;
    }

    .receipt-copy-system-note {
      font-size: 0.72rem !important;
      color: #666 !important;
      margin-top: 0.25rem !important;
    }

    /* RECEIPT_COPY_SYSTEM_STYLE_20260703_END */
/* RECEIPT_DINING_REVIEW_UI_START */
.receipt-ai-review-note {
  display: none !important;
}

.receipt-ai-needs-review {
  background: #fff !important;
  border-color: #bbb !important;
}

.receipt-ai-review-field {
  min-width: 7rem !important;
}
/* RECEIPT_DINING_REVIEW_UI_END */
    /* RECEIPT_CUSTOM_DIALOG_START */
    .receipt-dialog-backdrop {
      position: fixed;
      inset: 0;
      z-index: 999999;
      display: none;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.45);
      padding: 1.125rem;
      box-sizing: border-box;
    }

    .receipt-dialog-backdrop.open {
      display: flex;
    }

    .receipt-dialog-window {
      width: min(57.5rem, 96vw);
      max-height: 92vh;
      background: #fff;
      border: 0.125rem solid #222;
      border-radius: 0.625rem;
      box-shadow: 0 1.125rem 3.75rem rgba(0, 0, 0, 0.35);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .receipt-dialog-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.625rem;
      padding: 0.625rem 0.75rem;
      background: #222;
      color: #fff;
      font-weight: 800;
    }

    .receipt-dialog-head.warning {
      background: #7a4d00;
    }

    .receipt-dialog-head.error {
      background: #8a0018;
    }

    .receipt-dialog-body {
      padding: 0.75rem;
      overflow: auto;
    }

    .receipt-dialog-message {
      white-space: pre-wrap;
      line-height: 1.6;
      margin-bottom: 0.625rem;
      font-weight: 700;
    }

    .receipt-dialog-detail-label {
      font-size: 0.75rem;
      color: #555;
      margin: 0.5rem 0 0.25rem;
      font-weight: 700;
    }

    .receipt-dialog-detail {
      width: 100%;
      min-height: 13.75rem;
      max-height: 48vh;
      resize: vertical;
      box-sizing: border-box;
      font-family: Consolas, monospace;
      font-size: 0.75rem;
      line-height: 1.45;
      padding: 0.5rem;
      border: 0.0625rem solid #aaa;
      border-radius: 0.375rem;
      background: #fff;
      color: #111;
      white-space: pre;
    }

    .receipt-dialog-actions {
      display: flex;
      gap: 0.5rem;
      justify-content: flex-end;
      flex-wrap: wrap;
      padding: 0.625rem 0.75rem;
      border-top: 0.0625rem solid #ddd;
      background: #fafafa;
    }

    .receipt-dialog-actions button {
      min-width: 5.125rem;
      font-weight: 800;
    }

    .receipt-dialog-actions .primary {
      background: #222;
      color: #fff;
      border-color: #222;
    }
    /* RECEIPT_CUSTOM_DIALOG_END */
/* RECEIPT_TIME_AI_MINIMAL_FIX_20260704_START */

/* 時刻・会議費候補を黄色にしない */
.receipt-ai-review-note {
  display: none !important;
}

.receipt-ai-needs-review {
  background: #fff !important;
  border-color: #bbb !important;
}

#receiptTimeText {
  background: #fff !important;
  border-color: #bbb !important;
  color: #111 !important;
  box-shadow: none !important;
}

/* RECEIPT_TIME_AI_MINIMAL_FIX_20260704_END */
/* RECEIPT_TIME_ROW_REGEX_INSERT_20260704_START */

#formArea .receipt-date-payment-row {
  grid-template-columns: 18ch 9ch 26em !important;
}

#formArea #receiptTimeText {
  width: 9ch !important;
  min-width: 9ch !important;
  max-width: 9ch !important;
  height: 1.65rem !important;
  min-height: 1.65rem !important;
  box-sizing: border-box !important;
  text-align: center !important;
  background: #fff !important;
  border-color: #bbb !important;
  color: #111 !important;
  box-shadow: none !important;
}

/* RECEIPT_TIME_ROW_REGEX_INSERT_20260704_END */

    /* RECEIPT_RIGHT_SPACE_HALF_20260704_START */

    /*
      現在の並び：
      左：レシート選択
      中：読み取り候補の編集
      右：レシート表示スペース

      修正内容：
      - 右の画像表示スペースを前回拡張指定の約半分にする
      - レシート画像そのものの width / max-width / height / object-fit は触らない
      - %指定は使わない
    */

    main.receipt-compact-layout,
    .receipt-compact-layout {
      display: grid !important;
      grid-template-columns:
        clamp(9rem, 10vw, 12rem)
        minmax(30rem, 1fr)
        minmax(19rem, 0.85fr) !important;
      gap: 0.5rem !important;
      align-items: stretch !important;
      box-sizing: border-box !important;
      overflow: hidden !important;
    }

    .receipt-list-panel {
      order: 1 !important;
      min-width: 0 !important;
      overflow: hidden !important;
    }

    .receipt-candidate-panel {
      order: 2 !important;
      min-width: 0 !important;
      overflow: hidden !important;
    }

    .receipt-image-panel {
      order: 3 !important;
      min-width: 0 !important;
      overflow: hidden !important;
    }

    #imageArea {
      overflow: auto !important;
      box-sizing: border-box !important;
    }

    @media (max-width: 92rem) {
      main.receipt-compact-layout,
      .receipt-compact-layout {
        grid-template-columns:
          clamp(8rem, 10vw, 10rem)
          minmax(26rem, 1fr)
          minmax(15.5rem, 0.85fr) !important;
      }
    }

    @media (max-width: 76rem) {
      main.receipt-compact-layout,
      .receipt-compact-layout {
        grid-template-columns: 1fr !important;
        overflow: auto !important;
      }
    }

    /* RECEIPT_RIGHT_SPACE_HALF_20260704_END */

    /* RECEIPT_VENDOR_OVERFLOW_STOP_20260704 removed by group layout cleanup */

    /* RECEIPT_DATE_TIME_IN_VENDOR_CONTAINER_20260704 removed by group layout cleanup */

    /* RECEIPT_DATE_TIME_FLAT_IN_VENDOR_20260704 removed by group layout cleanup */

    /* RECEIPT_PAYMENT_AREA_CLEAN_FINAL_20260704_START */

    /*
      支払コンテナ周辺の整理版。
      ここでは input / select / button の height / min-height / padding は触らない。
      支払コンテナ本体、外枠、色、配置だけを制御する。
    */

    /* 支払方法・合計金額・消費税合計・内訳ボタンの専用コンテナ */
    #formArea .receipt-payment-amount-container {
      display: grid !important;
      grid-template-columns: 14rem 10rem 9rem max-content !important;
      gap: 0.5rem !important;
      align-items: end !important;

      width: calc(100% + 4rem) !important;
      max-width: none !important;
      min-width: 0 !important;

      min-height: 5rem !important;
      margin: 0.45rem -4rem 0.55rem 0 !important;
      padding: 0.85rem 0.45rem !important;

      border-radius: 0.55rem !important;

      box-sizing: border-box !important;
      overflow: visible !important;
    }

    /* 支払コンテナ内の子要素は、箱だけ整える。入力欄の高さは触らない。 */
    #formArea .receipt-payment-amount-container > div {
      min-width: 0 !important;
      box-sizing: border-box !important;
    }

    #formArea .receipt-payment-amount-container #totalAmount,
    #formArea .receipt-payment-amount-container #taxAmount {
      text-align: right !important;
      font-variant-numeric: tabular-nums !important;
    }

    #formArea .receipt-payment-amount-container #taxBreakdownButton {
      white-space: nowrap !important;
      align-self: end !important;
    }

    /* 移動後に元の金額行が空なら消す */
    #formArea .receipt-amount-direct-row:empty {
      display: none !important;
    }

    /* 店名・支払先コンテナ */
    #formArea .receipt-vendor-direct-stack {
      border-radius: 0.55rem !important;
      padding: 0.45rem !important;
      box-sizing: border-box !important;
    }

    /* 取引日・時刻は店名コンテナ内。カード化しない */
    #formArea .receipt-vendor-date-time-row {
      background: transparent !important;
      border: 0 !important;
      padding: 0 !important;
      margin: 0 0 0.35rem 0 !important;
      box-shadow: none !important;
    }

    #formArea .receipt-vendor-date-time-row > div {
      background: transparent !important;
      border: 0 !important;
      padding: 0 !important;
      margin: 0 !important;
      box-shadow: none !important;
      box-sizing: border-box !important;
    }

    /* 対象者 */
    #formArea .receipt-target-person-row {
      border-radius: 0.55rem !important;
      padding: 0.35rem !important;
      box-sizing: border-box !important;
    }

    /* 目的・案件・部門 */
    #formArea .receipt-master-combo-row {
      border-radius: 0.55rem !important;
      padding: 0.35rem !important;
      box-sizing: border-box !important;
    }

    /* インボイス区分・証憑区分・証憑メモ */
    #formArea .receipt-vendor-direct-stack .receipt-master-select-row {
      border-radius: 0.55rem !important;
      padding: 0.35rem !important;
      box-sizing: border-box !important;
    }

    @media (max-width: 86rem) {
      #formArea .receipt-payment-amount-container {
        width: 100% !important;
        max-width: 100% !important;
        margin-right: 0 !important;
      }
    }

    /* RECEIPT_PAYMENT_AREA_CLEAN_FINAL_20260704_END */
/* RECEIPT_GROUP_BOUNDARY_COLOR_DEBUG removed by group layout cleanup */


/* RECEIPT_CLEAN_GROUP_BOUNDARY_20260704 removed by basic group normalize */


/* RECEIPT_BASIC_GROUP_NORMALIZE_20260704_START */

/*
  基本情報グループ整理。
  解体済み：
  - .receipt-basic-left-stack
  - .receipt-master-select-row
  - .receipt-vendor-date-time-row

  残すグループ：
  - .receipt-payment-amount-container = 支払金額グループ
  - .receipt-target-person-row = 対象者グループ
  - .receipt-master-combo-row = 目的・案件・部門グループ
  - .receipt-vendor-direct-stack = 店名コンテナグループ
*/

#formArea .grid-basic-top-row {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) minmax(0, 24em) !important;
  grid-template-areas:
    "payment vendor"
    "target  vendor"
    "combo   vendor" !important;
  column-gap: 0.75rem !important;
  row-gap: 0.5rem !important;
  align-items: start !important;
  width: 100% !important;
  max-width: 100% !important;
  min-width: 0 !important;
  overflow: visible !important;
  box-sizing: border-box !important;
  outline-offset: 0.18rem !important;
}

#formArea .receipt-payment-amount-container {
  grid-area: payment !important;
  display: grid !important;
  grid-template-columns: 14rem 10rem 9rem max-content !important;
  gap: 0.5rem !important;
  align-items: end !important;
  width: 100% !important;
  max-width: none !important;
  min-width: 0 !important;
  margin: 0 0 0.45rem 0 !important;
  padding: 0.45rem !important;
  box-sizing: border-box !important;
  overflow: visible !important;
  outline-offset: 0.14rem !important;
}

#formArea .receipt-target-person-row {
  grid-area: target !important;
  width: 100% !important;
  max-width: 100% !important;
  min-width: 0 !important;
  box-sizing: border-box !important;
  outline-offset: 0.14rem !important;
}

#formArea .receipt-master-combo-row {
  grid-area: combo !important;
  display: grid !important;
  grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
  gap: 0.5rem !important;
  width: 100% !important;
  max-width: 100% !important;
  min-width: 0 !important;
  box-sizing: border-box !important;
  overflow: visible !important;
  outline-offset: 0.14rem !important;
}

#formArea .receipt-vendor-direct-stack {
  grid-area: vendor !important;
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) !important;
  gap: 0.45rem !important;
  width: 100% !important;
  max-width: 100% !important;
  min-width: 0 !important;
  margin: 0 !important;
  padding: 0.35rem !important;
  box-sizing: border-box !important;
  overflow: visible !important;
  outline-offset: 0.18rem !important;
}

#formArea .receipt-amount-direct-row:empty,
#formArea .receipt-date-payment-row:empty {
  display: none !important;
}

#formArea .receipt-vendor-direct-stack > div,
#formArea .receipt-payment-amount-container > div,
#formArea .receipt-target-person-row > div,
#formArea .receipt-master-combo-row > div {
  min-width: 0 !important;
  box-sizing: border-box !important;
}

#formArea .receipt-vendor-direct-stack > div:has(#transactionDate) {
  outline-offset: 0.1rem !important;
}

#formArea .receipt-vendor-direct-stack > div:has(#receiptTimeText) {
  outline-offset: 0.1rem !important;
}

#formArea .receipt-vendor-direct-stack > div:has(#vendorName) {
  outline-offset: 0.1rem !important;
}

#formArea .receipt-vendor-direct-stack > div:has(#vendorAddress) {
  outline-offset: 0.1rem !important;
}

#formArea .receipt-vendor-direct-stack > div:has(#vendorPhone) {
  outline-offset: 0.1rem !important;
}

#formArea .receipt-vendor-direct-stack > div:has(#invoiceNumber) {
  outline-offset: 0.1rem !important;
}

#formArea .receipt-vendor-direct-stack > div:has(#invoiceTypeId) {
  outline-offset: 0.1rem !important;
}

#formArea .receipt-vendor-direct-stack > div:has(#evidenceTypeId) {
  outline-offset: 0.1rem !important;
}

#formArea .receipt-vendor-direct-stack > div:has(#evidenceMemo) {
  outline-offset: 0.1rem !important;
}

/* RECEIPT_BASIC_GROUP_NORMALIZE_20260704_END */

    /* RECEIPT_VISIBLE_AREA_COLOR_20260704_START */
    /*
      現状確認用。
      色が見えるように、グループ本体と内側項目の背景を強めに塗る。
      線は付けない。
