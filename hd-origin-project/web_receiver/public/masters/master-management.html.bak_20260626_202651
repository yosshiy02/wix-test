<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <title>マスタ管理 - HD Origin Project</title>
  <style>
    body {
      font-family: system-ui, sans-serif;
      margin: 0;
      background: #f5f5f5;
      color: #222;
    }

    header {
      background: #222;
      color: white;
      padding: 12px 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    header h1 {
      margin: 0;
      font-size: 18px;
    }

    main {
      padding: 12px;
    }

    .card {
      background: white;
      border: 1px solid #ddd;
      border-radius: 10px;
      padding: 14px;
      margin-bottom: 12px;
      max-width: 920px;
    }

    .card h2 {
      margin: 0 0 10px;
      font-size: 18px;
    }

    label {
      display: block;
      font-weight: 700;
      font-size: 13px;
      margin-bottom: 3px;
    }

    input,
    select,
    button {
      box-sizing: border-box;
      padding: 6px 8px;
      font-size: 14px;
    }

    button {
      font-weight: 700;
      cursor: pointer;
      border: 1px solid #aaa;
      border-radius: 8px;
      background: #fff;
    }

    button:hover {
      background: #eee;
    }

    .button-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: end;
    }

    .form-row {
      display: grid;
      grid-template-columns: 160px 260px 90px 240px auto;
      gap: 10px;
      align-items: end;
    }

    table {
      border-collapse: collapse;
      background: white;
      width: 100%;
      margin-top: 10px;
    }

    th,
    td {
      border: 1px solid #ddd;
      padding: 5px;
      font-size: 13px;
      vertical-align: middle;
    }

    th {
      background: #eee;
    }

    .id-cell {
      width: 55px;
      text-align: right;
      color: #666;
    }

    .name-input {
      width: 260px;
    }

    .sort-input {
      width: 70px;
      text-align: right;
    }

    .memo-input {
      width: 240px;
    }

    .inactive {
      color: #999;
      background: #f7f7f7;
    }

    .danger {
      border-color: #b00020;
      color: #b00020;
    }

    .ok {
      border-color: #006b2e;
      color: #006b2e;
    }

    #result {
      white-space: pre-wrap;
      background: #f0f0f0;
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 8px;
      min-height: 42px;
      margin-top: 10px;
      font-size: 13px;
    }
  </style>
</head>
<body>
  <header>
    <h1>マスタ管理</h1>
    <div class="button-row">
      <button onclick="location.href='/'">メインへ</button>
      <button onclick="location.href='/expenses/expense-input.html'">経費入力</button>
    </div>
  </header>

  <main>
    <div class="card">
      <h2>管理対象</h2>

      <div class="button-row">
        <div>
          <label>マスタ</label>
          <select id="masterType" onchange="loadMasterItems()"></select>
        </div>

        <button onclick="loadMasterItems()">再読み込み</button>
      </div>

      <div id="result">待機中</div>
    </div>

    <div class="card">
      <h2>新規追加</h2>

      <div class="form-row">
        <div>
          <label>名称</label>
          <input id="newName" placeholder="新しい名称">
        </div>

        <div>
          <label>メモ</label>
          <input id="newMemo" placeholder="支払先のみ任意">
        </div>

        <div>
          <label>表示順</label>
          <input id="newSortOrder" type="number" value="0">
        </div>

        <div></div>

        <button onclick="addMasterItem()">追加</button>
      </div>
    </div>

    <div class="card">
      <h2>一覧</h2>
      <div id="masterList">読み込み中...</div>
    </div>
  </main>

<script>
let masterTypes = [];
let currentItems = [];

function showResult(data) {
  document.getElementById("result").textContent =
    typeof data === "string" ? data : JSON.stringify(data, null, 2);
}

function currentType() {
  return document.getElementById("masterType").value;
}

function currentTypeInfo() {
  return masterTypes.find(t => t.type === currentType()) || null;
}

async function loadMasterTypes() {
  const res = await fetch("/api/masters/types");
  const data = await res.json();

  if (!data.ok) {
    showResult(data);
    return;
  }

  masterTypes = data.types;

  const select = document.getElementById("masterType");
  select.innerHTML = "";

  for (const type of masterTypes) {
    const opt = document.createElement("option");
    opt.value = type.type;
    opt.textContent = type.label;
    select.appendChild(opt);
  }

  await loadMasterItems();
}

async function loadMasterItems() {
  const type = currentType();

  if (!type) return;

  const res = await fetch(`/api/masters?type=${encodeURIComponent(type)}`);
  const data = await res.json();

  if (!data.ok) {
    showResult(data);
    return;
  }

  currentItems = data.items;
  renderMasterList();
  showResult(`${currentTypeInfo().label} を読み込みました。`);
}

function renderMasterList() {
  const typeInfo = currentTypeInfo();
  const hasMemo = typeInfo && typeInfo.has_memo;

  if (!currentItems.length) {
    document.getElementById("masterList").textContent = "データがありません。";
    return;
  }

  let html = `
    <table>
      <tr>
        <th>ID</th>
        <th>名称</th>
        <th>表示順</th>
        <th>使用中</th>
        <th>${hasMemo ? "メモ" : "メモ"}</th>
        <th>操作</th>
      </tr>
  `;

  for (const item of currentItems) {
    const inactiveClass = item.is_active ? "" : "inactive";

    html += `
      <tr class="${inactiveClass}">
        <td class="id-cell">${item.id}</td>
        <td>
          <input class="name-input" id="name_${item.id}" value="${escapeHtml(item.name || "")}">
        </td>
        <td>
          <input class="sort-input" id="sort_${item.id}" type="number" value="${item.sort_order || 0}">
        </td>
        <td>
          <input id="active_${item.id}" type="checkbox" ${item.is_active ? "checked" : ""}>
        </td>
        <td>
          <input class="memo-input" id="memo_${item.id}" value="${escapeHtml(item.memo || "")}" ${hasMemo ? "" : "disabled"}>
        </td>
        <td>
          <button onclick="updateMasterItem(${item.id})">更新</button>
          <button class="${item.is_active ? "danger" : "ok"}" onclick="toggleActive(${item.id}, ${item.is_active ? "false" : "true"})">
            ${item.is_active ? "使用停止" : "使用再開"}
          </button>
        </td>
      </tr>
    `;
  }

  html += "</table>";
  document.getElementById("masterList").innerHTML = html;
}

function escapeHtml(value) {
  return String(value)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;");
}

async function addMasterItem() {
  const type = currentType();
  const typeInfo = currentTypeInfo();

  const payload = {
    type,
    name: document.getElementById("newName").value,
    sort_order: document.getElementById("newSortOrder").value,
    memo: typeInfo && typeInfo.has_memo ? document.getElementById("newMemo").value : ""
  };

  const res = await fetch("/api/masters", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(payload)
  });

  const data = await res.json();

  if (!data.ok) {
    showResult(data);
    return;
  }

  document.getElementById("newName").value = "";
  document.getElementById("newMemo").value = "";
  document.getElementById("newSortOrder").value = "0";

  showResult(data);
  await loadMasterItems();
}

async function updateMasterItem(id) {
  const type = currentType();
  const typeInfo = currentTypeInfo();

  const payload = {
    name: document.getElementById(`name_${id}`).value,
    sort_order: document.getElementById(`sort_${id}`).value,
    is_active: document.getElementById(`active_${id}`).checked,
    memo: typeInfo && typeInfo.has_memo ? document.getElementById(`memo_${id}`).value : ""
  };

  const res = await fetch(`/api/masters/${encodeURIComponent(type)}/${id}`, {
    method: "PUT",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(payload)
  });

  const data = await res.json();

  showResult(data);

  if (data.ok) {
    await loadMasterItems();
  }
}

async function toggleActive(id, active) {
  document.getElementById(`active_${id}`).checked = active;
  await updateMasterItem(id);
}

function enableEnterToNext() {
  document.addEventListener("keydown", event => {
    if (event.key !== "Enter") return;

    const tag = event.target.tagName.toLowerCase();

    if (!["input", "select"].includes(tag)) return;

    event.preventDefault();

    const fields = Array.from(document.querySelectorAll(
      'input:not([disabled]), select:not([disabled]), button:not([disabled])'
    )).filter(el => el.offsetParent !== null);

    const index = fields.indexOf(event.target);

    if (index >= 0 && fields[index + 1]) {
      fields[index + 1].focus();

      if (typeof fields[index + 1].select === "function") {
        fields[index + 1].select();
      }
    }
  });
}

enableEnterToNext();
loadMasterTypes();
</script>
</body>
</html>
