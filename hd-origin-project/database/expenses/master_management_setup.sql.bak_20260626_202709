UPDATE expenses.expense_headers h
SET invoice_type_id = t.invoice_type_id
FROM expenses.invoice_types t
WHERE h.invoice_type_id IS NULL
  AND h.invoice_status = t.invoice_type_name;

UPDATE expenses.expense_headers h
SET evidence_type_id = t.evidence_type_id
FROM expenses.evidence_types t
WHERE h.evidence_type_id IS NULL
  AND h.evidence_type = t.evidence_type_name;

UPDATE expenses.expense_headers h
SET invoice_status = t.invoice_type_name
FROM expenses.invoice_types t
WHERE h.invoice_type_id = t.invoice_type_id;

UPDATE expenses.expense_headers h
SET evidence_type = t.evidence_type_name
FROM expenses.evidence_types t
WHERE h.evidence_type_id = t.evidence_type_id;
