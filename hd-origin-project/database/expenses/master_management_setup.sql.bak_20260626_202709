CREATE TABLE IF NOT EXISTS expenses.invoice_types (
    invoice_type_id BIGSERIAL PRIMARY KEY,
    invoice_type_name TEXT NOT NULL UNIQUE,
    is_active BOOLEAN NOT NULL DEFAULT TRUE,
    sort_order INTEGER NOT NULL DEFAULT 0,
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS expenses.evidence_types (
    evidence_type_id BIGSERIAL PRIMARY KEY,
    evidence_type_name TEXT NOT NULL UNIQUE,
    is_active BOOLEAN NOT NULL DEFAULT TRUE,
    sort_order INTEGER NOT NULL DEFAULT 0,
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

ALTER TABLE expenses.expense_headers
  ADD COLUMN IF NOT EXISTS invoice_type_id BIGINT REFERENCES expenses.invoice_types(invoice_type_id),
  ADD COLUMN IF NOT EXISTS evidence_type_id BIGINT REFERENCES expenses.evidence_types(evidence_type_id);

