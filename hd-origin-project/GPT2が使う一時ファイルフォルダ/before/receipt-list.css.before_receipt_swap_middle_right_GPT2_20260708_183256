/* ---- extracted from receipt-list.html style block 1 ---- */
body {
      margin: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #f4f4f4;
      color: #222;
    }

    header {
      height: 3rem;
      box-sizing: border-box;
      padding: 0.75rem 1rem;
      background: #222;
      color: #fff;
      font-size: 1.125rem;
      font-weight: 700;
    }

    main {
      display: grid;
      grid-template-columns: 18.75rem 1fr 32.5rem;
      gap: 0.625rem;
      padding: 0.625rem;
      height: calc(100vh - 3rem);
      box-sizing: border-box;
    }

    .panel {
      background: #fff;
      border: 0.0625rem solid #ddd;
      border-radius: 0.5rem;
      overflow: hidden;
      min-height: 0;
    }

    .panel-title {
      height: 2.625rem;
      box-sizing: border-box;
      padding: 0.5625rem 0.625rem;
      border-bottom: 0.0625rem solid #ddd;
      background: #fafafa;
      font-weight: 700;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
    }

    .scroll {
      height: calc(100% - 2.625rem);
      overflow: auto;
    }

    .list-item {
      padding: 0.625rem;
      border-bottom: 0.0625rem solid #eee;
      cursor: pointer;
    }

    .list-item:hover {
      background: #f0f4ff;
    }

    .list-item.active {
      background: #e8f0ff;
      border-left: 0.25rem solid #333;
    }

    .list-main {
      font-weight: 700;
      margin-bottom: 0.25rem;
    }

    .list-sub {
      font-size: 0.75rem;
      color: #666;
      line-height: 1.5;
      word-break: break-all;
    }

    .image-area {
      height: calc(100% - 2.625rem);
      overflow: auto;
      background: #eee;
      text-align: center;
      padding: 0.625rem;
      box-sizing: border-box;
    }

    .image-area img {
      max-width: 100%;
      border: 0.0625rem solid #ccc;
      background: #fff;
    }

    .form-area {
      height: calc(100% - 2.625rem);
      overflow: auto;
      padding: 0.625rem;
      box-sizing: border-box;
    }

    .block {
      border: 0.0625rem solid #ddd;
      border-radius: 0.5rem;
      margin-bottom: 0.625rem;
      overflow: hidden;
      background: #fff;
    }

    .block-title {
      padding: 0.5rem 0.625rem;
      background: #fafafa;
      border-bottom: 0.0625rem solid #ddd;
      font-weight: 700;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
    }

    .block-body {
      padding: 0.625rem;
    }

    label {
      display: block;
      font-size: 0.75rem;
      font-weight: 700;
      margin-bottom: 0.25rem;
      color: #444;
    }

    input, textarea, select {
      width: 100%;
      box-sizing: border-box;
      padding: 0.4375rem;
      border: 0.0625rem solid #bbb;
      border-radius: 0.3125rem;
      font-size: 0.875rem;
      background: #fff;
    }

    textarea {
      min-height: 4rem;
      resize: vertical;
    }

    .grid2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }

    .grid1 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }

    button {
      border: 0.0625rem solid #aaa;
      background: #fff;
      padding: 0.4375rem 0.625rem;
      border-radius: 0.375rem;
      cursor: pointer;
    }

    button:hover {
      background: #f2f2f2;
    }

    button.primary {
      background: #222;
      color: #fff;
      border-color: #222;
    }

    button.primary:hover {
      background: #444;
    }

    button.danger {
      color: #b00020;
      border-color: #d8a0aa;
    }

    .actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 0.625rem;
    }

    .muted {
      color: #777;
      font-size: 0.75rem;
    }

    .warn {
      color: #b00020;
      font-weight: 700;
    }

    .ok {
      color: #087a28;
      font-weight: 700;
    }

    table.lines {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.8125rem;
    }

    table.lines th,
    table.lines td {
      border: 0.0625rem solid #ddd;
      padding: 0.3125rem;
      vertical-align: top;
    }

    table.lines th {
      background: #fafafa;
      font-weight: 700;
      white-space: nowrap;
    }

    table.lines input {
      padding: 0.3125rem;
      font-size: 0.8125rem;
    }

    .line-name {
      min-width: 9.375rem;
    }

    .line-small {
      width: 4.375rem;
    }

    .line-money {
      width: 5.625rem;
    }

    pre {
      white-space: pre-wrap;
      word-break: break-all;
      background: #111;
      color: #eee;
      padding: 0.625rem;
      border-radius: 0.375rem;
      font-size: 0.75rem;
      line-height: 1.5;
      max-height: 11.25rem;
      overflow: auto;
    }
  
    /* RECEIPT_HEADER_IMPORT_NAV */
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    header h1 {
      margin: 0;
    }

    .receipt-header-actions {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-left: auto;
    }

    .receipt-header-actions button {
      background: #fff;
      color: #111;
      border: 0.0625rem solid #fff;
      border-radius: 0.5rem;
      padding: 0.45rem 0.75rem;
      font-weight: 800;
      cursor: pointer;
      white-space: nowrap;
    }

    .receipt-header-actions button:hover {
      background: #f1f1f1;
    }
  
    /* RECEIPT_COMPACT_ACCOUNTING_LAYOUT */
    body {
      overflow: hidden;
    }

    .receipt-compact-layout {
      display: grid !important;
      grid-template-columns: 11.875rem minmax(42.5rem, 1fr) 20.625rem !important;
      gap: 0.375rem !important;
      height: calc(100vh - 3.625rem) !important;
      padding: 0.375rem 0.5rem !important;
      box-sizing: border-box !important;
      overflow: hidden !important;
    }

    .receipt-compact-layout > * {
      min-width: 0 !important;
      min-height: 0 !important;
      overflow: hidden !important;
    }

    .receipt-list-panel {
      order: 1 !important;
    }

    .receipt-candidate-panel {
      order: 2 !important;
    }

    .receipt-image-panel {
      order: 3 !important;
    }

    .receipt-list-panel .panel-title,
    .receipt-candidate-panel .panel-title,
    .receipt-image-panel .panel-title {
      padding: 0.375rem 0.5rem !important;
      font-size: 0.875rem !important;
      line-height: 1.2 !important;
    }

    .receipt-list-panel button,
    .receipt-list-panel .item {
      font-size: 0.75rem !important;
      line-height: 1.25 !important;
      padding: 0.375rem 0.4375rem !important;
    }

    .receipt-list-panel small,
    .receipt-list-panel .meta,
    .receipt-list-panel .sub {
      font-size: 0.625rem !important;
      line-height: 1.2 !important;
    }

    .receipt-list-panel {
      font-size: 0.75rem !important;
    }

    .receipt-candidate-panel {
      font-size: 0.75rem !important;
    }

    .receipt-image-panel {
      font-size: 0.75rem !important;
    }

    #formArea {
      height: calc(100vh - 7rem) !important;
      overflow: auto !important;
      padding: 0.5rem !important;
      box-sizing: border-box !important;
    }

    #formArea input,
    #formArea select,
    #formArea textarea {
      font-size: 0.75rem !important;
      padding: 0.25rem 0.375rem !important;
      min-height: 1.625rem !important;
      box-sizing: border-box !important;
    }

    #formArea textarea {
      min-height: 3rem !important;
      max-height: 4.75rem !important;
    }

    #formArea table {
      width: 100% !important;
      table-layout: fixed !important;
      font-size: 0.75rem !important;
    }

    #formArea th,
    #formArea td {
      padding: 0.1875rem !important;
      font-size: 0.75rem !important;
      vertical-align: middle !important;
    }

    #formArea button {
      font-size: 0.75rem !important;
      padding: 0.3125rem 0.5rem !important;
      min-height: 1.75rem !important;
    }

    #formArea .card,
    #formArea .section,
    #formArea fieldset {
      margin-bottom: 0.5rem !important;
      padding: 0.5rem !important;
    }

    #imageArea {
      height: calc(100vh - 7rem) !important;
      overflow: hidden !important;
      padding: 0.375rem !important;
      box-sizing: border-box !important;
      display: flex !important;
      align-items: flex-start !important;
      justify-content: center !important;
      background: #fff !important;
    }

    #imageArea img {
      max-width: 100% !important;
      max-height: 100% !important;
      width: auto !important;
      height: auto !important;
      object-fit: contain !important;
      cursor: zoom-in !important;
    }

    #receiptImageModal {
      position: fixed;
      inset: 0;
      z-index: 99999;
      display: none;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.78);
      padding: 1.125rem;
      box-sizing: border-box;
    }

    #receiptImageModal img {
      max-width: 96vw;
      max-height: 94vh;
      object-fit: contain;
      background: #fff;
      border-radius: 0.5rem;
      cursor: zoom-out;
    }

    #receiptImageModal .modal-note {
      position: fixed;
      top: 0.625rem;
      right: 1rem;
      color: #fff;
      font-size: 0.8125rem;
      background: rgba(0,0,0,0.45);
      padding: 0.375rem 0.625rem;
      border-radius: 0.375rem;
    }

    @media (max-width: 81.25rem) {
      .receipt-compact-layout {
        grid-template-columns: 10.625rem minmax(35rem, 1fr) 17.5rem !important;
      }
    }
