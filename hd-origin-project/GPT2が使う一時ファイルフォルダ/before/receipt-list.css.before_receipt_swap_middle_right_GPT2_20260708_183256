    }

    .tax-breakdown-table {
      width: 100%;
      border-collapse: collapse;
    }

    .tax-breakdown-table th,
    .tax-breakdown-table td {
      border-bottom: 0.0625rem solid #e5e5e5;
      padding: 0.45rem;
      vertical-align: middle;
      text-align: left;
    }

    .tax-breakdown-table th {
      font-size: 0.85rem;
      color: #555;
      white-space: nowrap;
    }

    .tax-breakdown-table select,
    .tax-breakdown-table input {
      width: 100%;
      box-sizing: border-box;
    }

    .tax-breakdown-footer {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: center;
      padding: 1rem 1.25rem;
      border-top: 0.0625rem solid #ddd;
    }

    .tax-breakdown-total {
      font-weight: 700;
    }

    .tax-breakdown-actions {
      display: flex;
