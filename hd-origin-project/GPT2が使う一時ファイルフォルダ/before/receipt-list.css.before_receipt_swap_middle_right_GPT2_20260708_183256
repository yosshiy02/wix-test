      padding: 0.625rem 0.75rem;
      background: #222;
      color: #fff;
      font-weight: 800;
    }

    .receipt-dialog-head.warning {
      background: #7a4d00;
    }

    .receipt-dialog-head.error {
      background: #8a0018;
    }

    .receipt-dialog-body {
      padding: 0.75rem;
      overflow: auto;
    }

    .receipt-dialog-message {
      white-space: pre-wrap;
      line-height: 1.6;
      margin-bottom: 0.625rem;
      font-weight: 700;
    }

    .receipt-dialog-detail-label {
      font-size: 0.75rem;
      color: #555;
      margin: 0.5rem 0 0.25rem;
      font-weight: 700;
    }

    .receipt-dialog-detail {
      width: 100%;
      min-height: 13.75rem;
      max-height: 48vh;
